# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Keepa
KEEPA_API_KEY=your_keepa_api_key
KEEPA_DOMAIN=US
KEEPA_STATS_DAYS=1
# Keepa API Access low tier refills about 20 tokens/minute. 3 seconds is a conservative default.
KEEPA_REQUEST_DELAY_SECONDS=3
# Buy Box data costs extra Keepa tokens, but is needed for buy_box_price.
KEEPA_FETCH_BUYBOX=true
# Amazon Best Sellers category used for the bsr column.
KEEPA_BSR_CATEGORY_ID=3303867011
KEEPA_BSR_CATEGORY_NAME=Best Sellers in Personal Fans
KEEPA_BESTSELLER_LIMIT=100
KEEPA_BESTSELLER_RANK_AVG_RANGE=0
KEEPA_BESTSELLER_SUBLIST=true
KEEPA_BESTSELLER_VARIATIONS=false

# LLM: DeepSeek or other OpenAI-compatible API
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-v4-flash
LLM_MAX_TOKENS=3000
LLM_TEMPERATURE=0.2

# DingTalk custom robot
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_access_token
# Optional. Fill only if the DingTalk robot enables signature verification.
DINGTALK_WEBHOOK_SECRET=

# Runtime
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai
ANALYSIS_TOP_DEALS_LIMIT=20
ANALYSIS_OFFSITE_CATEGORY=fan
# 日报展示用的品类中文名（与 ANALYSIS_OFFSITE_CATEGORY 对应的人类可读标签）
ANALYSIS_OFFSITE_CATEGORY_LABEL=手持风扇
# 自有/重点品牌：日报优先展开，且在 BSR 中单列。须与 config/brand_list.txt 中写法一致
ANALYSIS_FOCUS_BRAND=Diveblues
ANALYSIS_MAX_REASONABLE_PRICE=200
BESTSELLER_RANK_UP_THRESHOLD=10
# Keep recent offsite discoveries only. Set 0 to disable posted_at age filtering.
SLICKDEALS_MAX_POST_AGE_DAYS=30
