# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# LLM: DeepSeek or other OpenAI-compatible API
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-v4-flash
# deepseek-v4-flash 是推理模型，思考 token 也算进上限；设大一些避免长报告被截断（建议 ≥10000）
LLM_MAX_TOKENS=10000
LLM_TEMPERATURE=0.2

# DingTalk custom robot
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your_access_token
# Optional. Fill only if the DingTalk robot enables signature verification.
DINGTALK_WEBHOOK_SECRET=
# 钉钉单条消息字节上限保护（UTF-8），超出按整行截断；钉钉机器人上限约 20KB，默认留余量
DINGTALK_MARKDOWN_MAX_BYTES=19000

# Runtime
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai
# 爬虫请求重试与退避
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_SECONDS=3
# 站外 Deal 表名。旧生产库为 slickdeals_deals；执行 sql/008 重命名迁移后改为 offsite_deals
OFFSITE_DEALS_TABLE=slickdeals_deals
ANALYSIS_TOP_DEALS_LIMIT=20
ANALYSIS_OFFSITE_CATEGORY=fan
# 日报展示用的品类中文名（与 ANALYSIS_OFFSITE_CATEGORY 对应的人类可读标签）
ANALYSIS_OFFSITE_CATEGORY_LABEL=手持风扇
# 自有/重点品牌：日报优先展开。须与 config/brand_list.txt 中写法一致
ANALYSIS_FOCUS_BRAND=Diveblues
ANALYSIS_MAX_REASONABLE_PRICE=200
# 站外 Deal 价格下限（美元），低于此价直接丢弃（疑似噪音/非竞品）
ANALYSIS_MIN_OFFSITE_PRICE=5
# Keep recent offsite discoveries only. Set 0 to disable posted_at age filtering.
SLICKDEALS_MAX_POST_AGE_DAYS=30
